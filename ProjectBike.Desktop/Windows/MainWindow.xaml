<Window x:Class="ProjectBike.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ProjectBike.Desktop.Converters"
        xmlns:vm="clr-namespace:ProjectBike.Desktop.ViewModels.Clients"
        Title="System Wypożyczalni Rowerów" Height="450" Width="800">

    <Window.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Klienci" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Pobierz" Margin="12,0,0,0" Padding="10,4" Command="{Binding LoadCommand}" />
            <Button Content="Dodaj" Margin="8,0,0,0" Padding="10,4" Command="{Binding AddCommand}" />
            <Button Content="Rowery (Baza)" Margin="8,0,0,0" Padding="10,4" Command="{Binding OpenBikesCommand}" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8" Background="#EEE" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Wybrany Klient: " FontWeight="Bold"/>
                    <Run Text="{Binding SelectedClientName, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="Wypożycz / Zwróć" Padding="10,4" Margin="0,0,8,0" Command="{Binding ManageRentalsCommand}" />
                    <Button Content="Edytuj" Padding="10,4" Margin="0,0,8,0" Command="{Binding EditCommand}" />
                    <Button Content="Usuń" Padding="10,4" Command="{Binding DeleteCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Klient" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="Wypożyczenia" Binding="{Binding RentalsCount}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox Grid.Column="1" Header="Aktualne wypożyczenia klienta">
                <DataGrid ItemsSource="{Binding ClientRentals}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rower" Binding="{Binding BikeName}" Width="*" />
                        <DataGridTextColumn Header="Do dnia" Binding="{Binding EndDate, StringFormat={}{0:yyyy-MM-dd}}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>