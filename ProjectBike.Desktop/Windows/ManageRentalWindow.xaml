<Window x:Class="ProjectBike.Desktop.Windows.ManageRentalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzaj Wypożyczeniami" Height="520" Width="760" WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="{Binding TitleText}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="10" Background="#EEE" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Wybierz rower:" FontSize="10" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableBikes}" 
                              SelectedItem="{Binding SelectedAvailableBike}" 
                              DisplayMemberPath="Display" 
                              MinWidth="350"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Dni:" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding RentalDays, UpdateSourceTrigger=PropertyChanged}" 
                             Width="50" 
                             Padding="3"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="Wypożycz" 
                        Padding="14,6" 
                        Command="{Binding AddRentalCommand}" 
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <DataGrid ItemsSource="{Binding CurrentRentals}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rower" Binding="{Binding BikeName}" Width="*" />
                <DataGridTextColumn Header="Termin zwrotu" Binding="{Binding EndDate, StringFormat={}{0:yyyy-MM-dd}}" Width="140" />
                <DataGridTemplateColumn Header="Akcje" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Zwróć" 
                                    Padding="10,4" 
                                    Command="{Binding DataContext.ReturnBikeCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>