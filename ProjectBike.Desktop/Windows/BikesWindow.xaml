<Window x:Class="ProjectBike.Desktop.Windows.BikesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Baza Rowerow" Height="450" Width="720" WindowStartupLocation="CenterOwner">
    
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Rowery" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Pobierz" Margin="12,0,0,0" Padding="10,4" Command="{Binding LoadCommand}" />
            <Button Content="Dodaj" Margin="8,0,0,0" Padding="10,4" Command="{Binding AddCommand}" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8" Background="#EEE" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Wybrany rower: " FontWeight="Bold"/>
                    <Run Text="{Binding SelectedBikeName, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="Edytuj" Padding="10,4" Margin="0,0,8,0" Command="{Binding EditCommand}" />
                    <Button Content="Usun" Padding="10,4" Command="{Binding DeleteCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid ItemsSource="{Binding Bikes}" SelectedItem="{Binding SelectedBike}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Marka / Model" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="140" />
                <DataGridCheckBoxColumn Header="Dostepny" Binding="{Binding IsAvailable}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>